)
d_int <- d[, .(
chr,
start = as.integer(start),
end   = as.integer(end),
bin_name = name,
log2_ratio
)]
setkey(d_int, chr, start, end)
# x = features, y = bins
ov <- foverlaps(
x = features_int,
y = d_int,
by.x = c("chr", "start", "end"),
by.y = c("chr", "start", "end"),
type = "any",
nomatch = NA
)
# With x = features and y = bins:
# feature_id is kept as feature_id
# i.start / i.end are feature coords
# start / end are bin coords
feature_means <- ov[
,
.(
mean_log2_ratio = mean(log2_ratio, na.rm = TRUE),
n_bins = sum(!is.na(log2_ratio))
),
by = .(
feature_id,
chr,
feature_start = i.start,
feature_end   = i.end
)
][
order(feature_id)
]
feature_means[, file := f]
feature_means
}, BPPARM = BiocParallel::MulticoreParam(8, progressbar = T))
