) |>
dplyr::select(sample_id, mean_log2_ratio, feature) |>
tidyr::pivot_wider(names_from = feature, values_from = mean_log2_ratio, id_cols = sample_id) |>
tibble::column_to_rownames("sample_id")
arrow::write_parquet(cn_data_merge, "DB_test_classiflow/CN_MSQ_predictions/MSQ_CN_data.parquet")
}
