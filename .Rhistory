train_test_split <- function(d, name, seed = 42, outprefix = "DB_test_classiflow/data_stress_test") {  set.seed(seed)
data_split <- initial_split(iris, prop = 0.8)
train_data <- training(data_split)
test_data  <- testing(data_split)
write.csv(train_data, paste0(outprefix, "/", name, "_TRAIN.csv"), row.names = F, quote = F, col.names = T)
write.csv(test_data, paste0(outprefix, "/", name, "_TEST.csv"), row.names = F, quote = F, col.names = T)
}
