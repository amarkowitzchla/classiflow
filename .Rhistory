library(data.table)
library(rjson)
library(GenomicRanges)
library(BiocParallel)
if (0) {
cf_config <- fromJSON(
file = "DB_test_classiflow/projects/CNS_CN_HIERA__cns_cn_hierarchical_20260411/runs/final_model/bbf0a20c4664/run.json"
)
feature_strings <- cf_config[["feature_list"]]
features <- data.frame(
chr   = gsub(":.*", "", feature_strings),
start = as.integer(gsub(".*:|-.*", "", feature_strings)),
end   = as.integer(gsub(".*-", "", feature_strings))
) |>
as.data.table()
features[, feature_id := .I]
# Keep original feature coordinates with explicit names
features_int <- features[, .(
feature_id,
chr,
feature_start = start,
feature_end   = end
)]
# foverlaps requires interval cols named start/end
setnames(features_int, c("feature_start", "feature_end"), c("start", "end"))
setkey(features_int, chr, start, end)
tn_files <- list.files(
"/Volumes/DNB_External_1/data/methylseq/databricks_dashboard/Patient-Analysis_copy/",
pattern = "tn.tsv.gz$",
recursive = TRUE,
full.names = TRUE
)
cn_data <- bplapply(tn_files, function(f) {
d <- fread(
f,
col.names = c(
"chr",
"start",
"end",
"name",
"log2_ratio",
"improper_pairs"
)
)
d_int <- d[, .(
chr,
start = as.integer(start),
end   = as.integer(end),
bin_name = name,
log2_ratio
)]
setkey(d_int, chr, start, end)
# x = features, y = bins
ov <- foverlaps(
x = features_int,
y = d_int,
by.x = c("chr", "start", "end"),
by.y = c("chr", "start", "end"),
type = "any",
nomatch = NA
)
# With x = features and y = bins:
# feature_id is kept as feature_id
# i.start / i.end are feature coords
# start / end are bin coords
feature_means <- ov[
,
.(
mean_log2_ratio = mean(log2_ratio, na.rm = TRUE),
n_bins = sum(!is.na(log2_ratio))
),
by = .(
feature_id,
chr,
feature_start = i.start,
feature_end   = i.end
)
][
order(feature_id)
]
feature_means[, file := f]
return(feature_means)
}, BPPARAM = MulticoreParam(8, progressbar = T))
cn_data_merge <- rbindlist(cn_data, use.names = TRUE, fill = TRUE)
cn_data_merge <- cn_data_merge |>
as.data.frame() |>
dplyr::mutate(
feature = paste0(GRanges(cn_data_merge)),
sample_id = gsub(".*\\/|_MSQ.*", "", file),
